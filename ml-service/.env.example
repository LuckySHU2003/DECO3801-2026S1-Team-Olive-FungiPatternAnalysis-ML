APP_ENV=development
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=120
TMP_DIR=/tmp/mycosignal-ml-service

# MongoDB — ML-service resolves dataset_id/model_id itself
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<dbname>
MONGODB_DATABASE=fungipatternanalysis
DATASETS_COLLECTION=datasets
MODELS_COLLECTION=modelmetadatas

# Supabase — ML-service generates signed download URLs itself
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DATASETS_BUCKET=datasets
SUPABASE_MODELS_BUCKET=models