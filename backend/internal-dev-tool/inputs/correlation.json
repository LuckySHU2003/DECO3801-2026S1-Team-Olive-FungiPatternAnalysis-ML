{
  "job": "correlation_analysis",
  "dataset": {
    "path": "./data/processed_data.csv",
    "columns": {
      "time": "Time",
      "voltage": "Voltage",
      "temperature": "Temperature",
      "ph": "pH"
    }
  },
  "preprocessing": {
    "mode": "raw"
  },
  "correlation_config": {
    "main_metric": "Voltage",
    "external_variables": ["Temperature", "pH"],
    "regression_method": "linear"
  },
  "species_benchmark": {
    "enabled": true,
    "species": "species_a",
    "benchmark_model_path": "./models/species_a.pkl"
  },
  "model": {
    "name": "correlation_model",
    "type": "pkl",
    "path": "./models/correlation_model.pkl"
  }
}