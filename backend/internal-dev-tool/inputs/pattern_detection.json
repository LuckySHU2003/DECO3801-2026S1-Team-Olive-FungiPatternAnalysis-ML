{
  "job": "pattern_detection",
  "dataset": {
    "path": "./data/processed_data.csv",
    "columns": {
      "time": "Time",
      "voltage": "Voltage"
    }
  },
  "preprocessing": {
    "mode": "raw"
  },
  "detection_config": {
    "threshold": 0.7,
    "window_size": 100,
    "pattern_types": ["spike", "oscillation"]
  },
  "model": {
    "name": "rf_pattern_model",
    "type": "pkl",
    "path": "./models/rf_pattern.pkl"
  }
}