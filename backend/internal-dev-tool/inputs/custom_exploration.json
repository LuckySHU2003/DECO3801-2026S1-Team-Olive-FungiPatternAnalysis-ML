{
  "job": "custom_pattern_exploration",
  "dataset": {
    "path": "./data/processed_data.csv",
    "columns": {
      "time": "Time",
      "voltage": "Voltage"
    }
  },
  "preprocessing": {
    "mode": "detrended"
  },
  "analysis_config": {
    "threshold": 0.5,
    "window_size": 200,
    "time_range": {
      "start": 0,
      "end": 500
    },
    "model_selection": "rf"
  },
  "model": {
    "name": "rf_pattern_model",
    "type": "pkl",
    "path": "./models/rf_pattern.pkl"
  }
}